# The build engine is a pinned VSCodium clone — regenerable, large, and has its
# own .git. Recreate with:
#   git clone --depth 1 https://github.com/VSCodium/vscodium.git build-engine
#   (cd build-engine && git remote rename origin upstream)
build-engine/

# Downloaded extension VSIX cache (large, regenerable via fetch-extensions.sh).
# The builtin.<target>.json manifests ARE tracked (they pin versions).
overlay/extensions/vsix/
overlay/extensions/*/*.version

# Build artifacts
VSCode-*/
*.dmg
*.zip
*.log
diagnose-win.log

# Quarto render artifacts of bundled help docs
overlay/builtin-extensions/*/help.html
overlay/builtin-extensions/*/*_files/

# Quarto site: rendered output (deployed by CI) + cache
site/_site/
site/.quarto/

# App Store Connect API keys (notarization secrets) — never commit
AuthKey_*.p8
*.p8

# Personal outreach contact lists — do not publish
email/

# Playwright MCP output (screenshots, traces)
.playwright-mcp/

# voiceover package is generated from kerryback/skills (scripts/sync-from-marketplace.sh voiceover)
/packages/voiceover/

# finance-data package is generated from kerryback/skills (scripts/sync-from-marketplace.sh finance-data)
/packages/finance-data/

# slides package is generated from kerryback/skills (scripts/sync-from-marketplace.sh slides)
/packages/slides/
