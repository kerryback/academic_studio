{
  "name": "academic-studio-defaults",
  "displayName": "Academic Studio Defaults",
  "description": "Default settings for Academic Studio. Built in; sets beginner-friendly, academic-workflow defaults. Any setting here can be overridden by the user.",
  "version": "1.0.0",
  "publisher": "academic-studio",
  "license": "MIT",
  "engines": { "vscode": "^1.121.0" },
  "categories": ["Other"],
  "main": "./extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      {
        "command": "academicStudio.openTour",
        "title": "Tour of Academic Studio",
        "category": "Help"
      },
      {
        "command": "academicStudio.openHelp",
        "title": "Academic Studio Help",
        "category": "Help"
      },
      {
        "command": "academicStudio.checkForUpdates",
        "title": "Check for Updates…",
        "category": "Help"
      },
      {
        "command": "academicStudio.about",
        "title": "About Academic Studio",
        "category": "Help"
      },
      {
        "command": "academicStudio.newLatexFile",
        "title": "LaTeX File",
        "category": "LaTeX"
      },
      {
        "command": "academicStudio.newMarkdownFile",
        "title": "Markdown File",
        "category": "Markdown"
      }
    ],
    "menus": {
      "file/newFile": [
        { "command": "academicStudio.newLatexFile", "group": "file" },
        { "command": "academicStudio.newMarkdownFile", "group": "file" }
      ]
    },
    "configurationDefaults": {
      "files.autoSave": "afterDelay",
      "files.autoSaveDelay": 1000,
      "editor.minimap.enabled": false,
      "editor.stickyScroll.enabled": false,
      "editor.renderWhitespace": "none",
      "breadcrumbs.enabled": true,
      "telemetry.telemetryLevel": "off",
      "redhat.telemetry.enabled": false,
      "workbench.colorTheme": "Visual Studio Light",
      "workbench.startupEditor": "welcomePage",
      "workbench.editorAssociations": { "*.md": "default", "*.markdown": "default" },
      "workbench.tips.enabled": false,
      "workbench.reduceMotion": "on",
      "security.workspace.trust.startupPrompt": "never",
      "security.workspace.trust.banner": "never",
      "git.openRepositoryInParentFolders": "never",
      "git.confirmSync": false,
      "extensions.ignoreRecommendations": true,
      "chat.commandCenter.enabled": false,
      "python.languageServer": "None",
      "python.terminal.activateEnvironment": true,
      "basedpyright.analysis.typeCheckingMode": "standard",
      "latex-workshop.view.pdf.internal.synctex.keybinding": "double-click",
      "latex-workshop.view.autoFocus.enabled": true,
      "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/*.aux": true,
        "**/*.bbl": true,
        "**/*.blg": true,
        "**/*.bcf": true,
        "**/*.run.xml": true,
        "**/*.fdb_latexmk": true,
        "**/*.fls": true,
        "**/*.synctex.gz": true,
        "**/*.toc": true,
        "**/*.lof": true,
        "**/*.lot": true,
        "**/*.out": true,
        "**/*.nav": true,
        "**/*.snm": true,
        "**/*.vrb": true
      },
      "[markdown]": { "editor.wordWrap": "on", "editor.quickSuggestions": { "comments": "off", "strings": "off", "other": "off" } },
      "[quarto]": { "editor.wordWrap": "on" },
      "[latex]": { "editor.wordWrap": "on", "editor.wrappingIndent": "indent" },
      "[tex]": { "editor.wordWrap": "on", "editor.wrappingIndent": "indent" },
      "[bibtex]": { "editor.wordWrap": "on" }
    }
  }
}
