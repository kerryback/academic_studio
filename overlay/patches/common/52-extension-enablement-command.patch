 			return [];
 		}
 	}]);
+
+// Academic Studio: let the setup extension enable/disable bundled extensions.
+CommandsRegistry.registerCommand('academicStudio.setExtensionsEnablement', async (accessor: ServicesAccessor, ids: string[], enabled: boolean) => {
+	const service = accessor.get(IExtensionsWorkbenchService);
+	const wanted = (ids || []).map(id => id.toLowerCase());
+	const targets = service.installed.filter(e => wanted.indexOf(e.identifier.id.toLowerCase()) !== -1);
+	if (!targets.length) { return; }
+	await service.setEnablement(targets, enabled ? EnablementState.EnabledGlobally : EnablementState.DisabledGlobally);
+});
